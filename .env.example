# Shared app API base for frontend (Vite)
VITE_APP_API_BASE_URL=http://localhost:8787

# Bridge/server settings
ALERT_SERVER_PORT=8787
ALERT_SHARED_SECRET=

# Breach checker provider (server-side only)
